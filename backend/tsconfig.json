{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "dom"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@helpers/*": ["helpers/*"],
      "@data/*": ["data/*"]
    }
  },
  "include": ["src/**/*.ts", "src/../tests/**/*.ts", "src/../helpers/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
